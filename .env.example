# Database
DATABASE_URL="mysql://user:password@localhost:3306/ufo_networks"

# Session (required in production)
NUXT_SESSION_PASSWORD="change-me-to-a-long-random-string"

# Paynow (required for voucher payments)
PAYNOW_INTEGRATION_ID=""
PAYNOW_INTEGRATION_KEY=""
# Merchant email registered with Paynow (recommended for live/test payments)
PAYNOW_AUTH_EMAIL=""

# Alternative Nuxt-prefixed names (also supported)
# NUXT_PAYNOW_INTEGRATION_ID=""
# NUXT_PAYNOW_INTEGRATION_KEY=""
# NUXT_PAYNOW_AUTH_EMAIL=""
